# Server
PORT=3000
NODE_ENV=development

# Session
SESSION=your-super-secret-session-key-change-this

# Database
DB_NAME=snip_db
DB_USER=root
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306

# Security
SALT=10

# Optional: Redis (for session store + cache)
REDIS_URL=redis://localhost:6379

# Optional: AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=snip-files
