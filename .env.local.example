# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=snip
DB_USER=snip
DB_PASSWORD=snip_password

# ── Session ───────────────────────────────────────────────────────────────────
# Must be at least 32 characters for iron-session
SESSION=replace-with-a-random-secret-32-chars-min

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Optional ──────────────────────────────────────────────────────────────────
SALT=10
