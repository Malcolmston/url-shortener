{
  "name": "snip",
  "version": "1.0.0",
  "description": "Short links. Big control.",
  "main": "app.js",
  "scripts": {
    "start": "ts-node app.js",
    "dev": "nodemon --exec ts-node app.js",
    "build": "cd short && npm install && npm run build",
    "build:backend": "tsc --outDir dist",
    "migrate": "sequelize-cli db:migrate",
    "seed": "sequelize-cli db:seed:all",
    "test": "jest"
